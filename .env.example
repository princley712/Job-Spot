# ── Database ──────────────────────────────────────────────
# PostgreSQL connection string: postgresql+psycopg2://user:pass@host:port/dbname
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/jobtracker

# ── Redis / Celery ────────────────────────────────────────
# Redis connection string: redis://host:port/db
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── JWT / Auth ────────────────────────────────────────────
# Generate a random secret key using: openssl rand -hex 32
SECRET_KEY=change-me-to-a-secure-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Scraper ───────────────────────────────────────────────
SCRAPER_HEADLESS=True
SCRAPER_TIMEOUT_MS=30000
SCRAPER_MAX_CONCURRENT=3
SCRAPER_REQUEST_DELAY_S=2.0
# SCRAPER_PROXY=http://user:pass@proxy.example.com:8080

# ── Matching ──────────────────────────────────────────────
MATCH_SCORE_THRESHOLD=0.25
TFIDF_MAX_FEATURES=5000

# ── Application Expiry ────────────────────────────────────
APPLICATION_EXPIRY_DAYS=7
